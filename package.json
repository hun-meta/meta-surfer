{
  "name": "meta-surfer",
  "version": "0.2.0",
  "description": "AI-powered web search engine — CLI, library, and optional web UI. Self-hosted Perplexity alternative with multi-provider LLM support.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "meta-surfer": "./bin/meta-surfer.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "search",
    "perplexity",
    "web-search",
    "cli",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "grok",
    "self-hosted",
    "searxng",
    "vercel-ai-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hun-meta/meta-surfer.git"
  },
  "homepage": "https://github.com/hun-meta/meta-surfer#readme",
  "bugs": {
    "url": "https://github.com/hun-meta/meta-surfer/issues"
  },
  "author": "hun-meta",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:lib": "tsup",
    "build:web": "next build",
    "build": "tsup && next build",
    "dev": "next dev",
    "dev:cli": "tsx src/cli.ts",
    "start": "next start",
    "lint": "next lint",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/xai": "^1.2.18",
    "ai": "^4.3.19",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "^1.2.12",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "lucide-react": "^0.468.0",
    "next": "^15.5.12",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "tailwind-merge": "^2.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
