# Z.AI LLM Configuration
ZAI_API_KEY=your-zai-api-key
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5

# SearXNG (local meta search engine)
SEARXNG_URL=http://localhost:8080

# Crawl4AI (web scraping service)
CRAWL4AI_URL=http://localhost:11235

# Piston (code execution sandbox)
PISTON_URL=http://localhost:2000

# SearXNG outbound proxy (optional, for avoiding rate limits)
# Supports http://, https://, socks5h:// formats
# SEARXNG_PROXY_URL=http://user:pass@proxy-host:port
