# LLM Provider (auto-detected from API keys if omitted)
# Options: openai, google, anthropic, xai, zai
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.1-chat-latest

# OpenAI
OPENAI_API_KEY=sk-...

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# xAI (Grok)
XAI_API_KEY=your-xai-api-key

# Z.AI (OpenAI-compatible)
ZAI_API_KEY=your-zai-api-key
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# SearXNG (local meta search engine)
SEARXNG_URL=http://localhost:8080

# Crawl4AI (web scraping service)
CRAWL4AI_URL=http://localhost:11235

# Piston (code execution sandbox)
PISTON_URL=http://localhost:2000

# SearXNG outbound proxy (required for stable search performance)
# Without a proxy, upstream search engines will rate-limit and timeout frequently.
# Supports http://, https://, socks5h:// formats
SEARXNG_PROXY_URL=http://user:pass@proxy-host:port
